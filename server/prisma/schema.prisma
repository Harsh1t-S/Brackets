generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String
  role     Role   @default(USER)

  // Small data-URI image uploaded by the user (resized client-side).
  avatar String? @db.Text

  // Admin promotion audit: who flipped this user to ADMIN, and when. Both are
  // null for seeded admins and for anyone who has never been promoted. The
  // self-relation is SetNull so removing the promoter doesn't block the
  // delete or orphan the FK — the record just loses its "promoted by" name.
  promotedById String?
  promotedBy   User?     @relation("AdminPromotions", fields: [promotedById], references: [id], onDelete: SetNull)
  promoted     User[]    @relation("AdminPromotions")
  promotedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  problems Problem[]
  bookmarks Bookmark[]
  votes    ProblemVote[]
  solved   SolvedProblem[]
  lists    ProblemList[]
}

model SolvedProblem {
  id String @id @default(cuid())

  userId    String
  problemId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, problemId])
}

enum ListVisibility {
  PRIVATE
  PUBLIC
}

/**
 * A user-curated collection of problems ("DP grind", "Interview prep").
 *
 * Every user gets one list flagged `isDefault` — their Favourites — which is
 * what the bookmark button writes to, so bookmarking stays one click and the
 * old Bookmark rows had somewhere to land.
 */
model ProblemList {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text

  /** Public lists are readable by anyone holding the link, via this slug. */
  slug       String         @unique
  visibility ListVisibility @default(PRIVATE)

  /** The built-in Favourites list. Exactly one per user; cannot be deleted. */
  isDefault Boolean @default(false)

  items ProblemListItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Two people may both have a "Favourites"; one person may not have two.
  @@unique([userId, name])
  @@index([userId])
}

model ProblemListItem {
  id String @id @default(cuid())

  listId    String
  problemId String

  list    ProblemList @relation(fields: [listId], references: [id], onDelete: Cascade)
  problem Problem     @relation(fields: [problemId], references: [id], onDelete: Cascade)

  /** Manual ordering within a list; ties fall back to when it was added. */
  position Int @default(0)

  createdAt DateTime @default(now())

  @@unique([listId, problemId])
  @@index([listId])
}

model Problem {
  id String @id @default(cuid())

  number Int @unique

  title String
  slug  String @unique

  description String @db.Text

  difficulty Difficulty

  constraints String? @db.Text

  examples Json

  starterCode Json

  solutionCode Json

  tags String[]

  companies String[] @default([])

  createdById String?

  // Deleting an author leaves their problems in place, just unattributed.
  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  acceptance Float @default(0)
  likes      Int   @default(0)
  dislikes   Int   @default(0)
  premium    Boolean @default(false)
  bookmarks Bookmark[]
  testCases TestCase[]
  votes     ProblemVote[]
  solvedBy  SolvedProblem[]
  listItems ProblemListItem[]

  // List filters hit these constantly; GIN makes the array
  // containment/overlap operators (@>, &&) index-backed.
  @@index([difficulty])
  @@index([tags(ops: ArrayOps)], type: Gin)
  @@index([companies(ops: ArrayOps)], type: Gin)
}

model ProblemVote {
  id String @id @default(cuid())

  userId    String
  problemId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  value Int // 1 = like, -1 = dislike

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, problemId])
}

model TestCase {
  id String @id @default(cuid())

  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  input  String @db.Text
  output String @db.Text

  isHidden Boolean @default(false)
  order    Int     @default(0)

  createdAt DateTime @default(now())
}
model Bookmark {
  id        String   @id @default(cuid())

  userId    String
  problemId String

  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem    Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, problemId])
}